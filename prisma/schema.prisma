generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Event {
  id               String   @id
  slug             String   @unique
  type             String   // "upcoming" | "past"
  title            String
  date             String
  dateDisplay      String
  time             String?
  location         String
  locationShort    String?
  price            String?
  priceNote        String?
  heroImage        String
  heroTagline      String?   // HTML, текст под заголовком в hero
  heroTitleTop     String?   // первая строка в hero (BLOOM)
  heroTitleBottom  String?   // вторая строка в hero (OF ENERGY)
  tag              String?
  tagStyle         String?
  metaTitle        String
  metaDescription  String
  artists          String   // JSON array
  tickets          String   // JSON array
  aboutParagraphs  String   // JSON array
  venueTitle       String
  venueAddress     String
  venueCity        String
  buyTicketUrl     String?
  age              String?
  dressCode        String?
  rules            String?
  subtitle         String?
  gallery          String?  // JSON array of photo paths
  logoScrolled     String?  // логотип после hero (квадратный) для страницы мероприятия
  heroVideo        String?  // видео-превью: показывается в шапке при скролле (проваливаешься)
  sortOrder        Int?     // порядок в списке (меньше = выше); null = по дате
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Main {
  id        String   @id @default("main")
  hero      String   // JSON
  about     String   // JSON
  gallery   String   // JSON
  reviews   String   // JSON
  updatedAt DateTime @updatedAt
}

model Meta {
  id             String   @id @default("meta")
  title          String
  description    String
  canonical      String?
  googleFontUrl  String?  // ссылка на CSS Google Fonts (прогрессивная загрузка)
  fontFamily     String?  // имя шрифта для --font-sans, напр. "Manrope"
  updatedAt      DateTime @updatedAt
}

model ChatSettings {
  id              String   @id @default("chat")
  enabled         Boolean  @default(true)
  botToken        String?
  telegramChatId  String?
  workStartMsk    String?
  workEndMsk      String?
  updatedAt       DateTime @updatedAt
}

model ChatMessage {
  id                String   @id @default(cuid())
  sessionId         String
  text              String
  fromAdmin         Boolean  @default(false)
  telegramMessageId Int?
  createdAt         DateTime @default(now())
}

model ChatReplyState {
  id             String   @id @default(cuid())
  telegramUserId String   @unique
  sessionId      String
  createdAt      DateTime @default(now())
}
