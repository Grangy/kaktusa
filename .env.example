# БД
DATABASE_URL="file:./prisma/dev.db"

# NextAuth
AUTH_SECRET="сгенерируйте: openssl rand -base64 32"

# Админка
ADMIN_PASSWORD="ваш_пароль"

# Деплой и сборка (для npm run deploy / deploy:light)
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="сгенерируйте: openssl rand -base64 32"

# Деплой (обязательно для npm run deploy / deploy:light / deploy:update и т.д.)
DEPLOY_SERVER="ваш_сервер_или_ip"
DEPLOY_SSH_KEY="/путь/к/приватному/ключу"
# DEPLOY_USER="root"
# DEPLOY_REMOTE="/var/www/kaktusa"
